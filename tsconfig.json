/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@cyia/ngx-vueuse/core": [
        "./projects/vueuse-lib/core/index.ts"
      ],
      "@cyia/ngx-vueuse/math": [
        "./projects/vueuse-lib/math/index.ts"
      ],
      "@cyia/ngx-vueuse/patch": [
        "./projects/vueuse-lib/patch/index.ts"
      ],
      "@cyia/ngx-vueuse/shared": [
        "./projects/vueuse-lib/shared/index.ts"
      ],
      "@cyia/ngx-vueuse/test": [
        "./projects/vueuse-lib/test/index.ts"
      ],
    },
    "lib": [
      "ESNext",
      "DOM"
    ]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    },
    {
      "path": "./projects/vueuse-lib/tsconfig.lib.json"
    },
    {
      "path": "./projects/vueuse-lib/tsconfig.spec.json"
    }
  ]
}